# LLM Provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Agent config
SPIDER_MODEL=gpt-4o
SPIDER_MAX_ITERATIONS=25
SPIDER_ALLOW_EXTERNAL=false

# Memory compaction
SPIDER_COMPACT_ENABLED=true
SPIDER_CONTEXT_LIMIT=128000
SPIDER_COMPACT_THRESHOLD=0.75
SPIDER_RESERVE_EXCHANGES=5

# Memory persistence (deja vacio para ~/.spider/memory/)
SPIDER_MEMORY_DIR=
